# Theme.
theme = Catppuccin Mocha
# Thick cursor.
cursor-style = block
cursor-style-blink = false
# ssh-env: Solves ssh issues https://ghostty.org/docs/help/terminfo#ssh
# no-cursor: This is needed for custom cursor styles. See https://ghostty.org/docs/config/reference#cursor-style
shell-integration-features = ssh-env,no-cursor
